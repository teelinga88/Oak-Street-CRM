rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only authenticated users can read/write
    // Managers (Alex, Bobby) can read all reps' data
    // Reps can only read/write their own data

    function isAuth() {
      return request.auth != null;
    }

    function isManager() {
      return request.auth.token.email in [
        'alex@oakstreetlogistics.com',
        'bobby@oakstreetlogistics.com'
      ];
    }

    function isOwner(repName) {
      return request.auth != null && (
        isManager() ||
        resource.data.rep == repName
      );
    }

    match /accounts/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    match /deals/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    match /followups/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    match /bucket/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
  }
}
